PORT=10000
NODE_ENV=development

# 正式 Render 使用 PostgreSQL。留空或设置 DB_MODE=memory 时使用内存模式，仅适合本地测试。
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
DB_MODE=postgres
JWT_SECRET=replace-with-at-least-32-random-characters

# 同时填写学生端和家长端域名，英文逗号分隔。
CORS_ORIGIN=https://aixuexi-29x.pages.dev,https://your-parent.pages.dev,http://localhost:5173
MAX_JSON_MB=30

# 可选：OpenAI 兼容模型接口。未配置时，OCR/AI接口仍返回结构化兜底结果，不会404。
AI_API_BASE_URL=
AI_API_KEY=
AI_MODEL=gpt-4.1-mini
AI_VISION_MODEL=gpt-4.1-mini
